{
    "name": "chanondb/symfony7-cookie-consent-bundle",
    "type": "symfony-bundle",
    "description": "Fork: Symfony Cookie Consent (Symfony 8 + Doctrine 3). Upstream: chanondb/symfony7-cookie-consent-bundle.",
    "license": "MIT",
    "version": "8.0.0",
    "authors": [
        {
            "name": "Chanond buranabunpot",
            "email": "chanond.b@app-alive.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "doctrine/dbal": "^4.0",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.2",
        "symfony/asset": "^8.0",
        "symfony/dependency-injection": "^8.0",
        "symfony/doctrine-bridge": "^8.0",
        "symfony/expression-language": "^8.0",
        "symfony/form": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/http-foundation": "^8.0",
        "symfony/http-kernel": "^8.0",
        "symfony/translation": "^8.0",
        "symfony/twig-bridge": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpunit/phpunit": "^11.0",
        "symfony/yaml": "^8.0"
    },
    "prefer-stable": true,
    "autoload": {
        "exclude-from-classmap": [
            "/Tests/"
        ],
        "psr-4": {
            "Chanondb\\CookieConsentBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Chanondb\\CookieConsentBundle\\Tests\\": "src/Tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
